---
import { t, type Locale } from '../i18n';

interface Props {
  class?: string;
  locale: Locale;
}
const { class: className, locale } = Astro.props;
---

<div class={` flex flex-col items-center justify-center p-4 md:p-6 ${className}`}>
  <main class="w-full max-w-xl">
    <section class="bg-white rounded-xl shadow-sm border border-slate-200/80 p-6 md:p-8">
      <h1 class="text-xl md:text-2xl font-semibold text-slate-800 tracking-tight">
        {t(locale, 'thailand.title')}
      </h1>
      <p class="mt-2 text-sm text-slate-500">
        {t(locale, 'thailand.subtitle')}
      </p>

      <form
        action="/api/thailand"
        method="POST"
        class="mt-6 space-y-5"
      >
        <div class="grid gap-5 md:grid-cols-2">
          <div>
            <label for="playerSign" class="block text-sm font-medium text-slate-700 mb-1.5">
              {t(locale, 'thailand.fields.playerSign')}
            </label>
            <input
              type="text"
              id="playerSign"
              name="playerSign"
              placeholder={t(locale, 'thailand.fields.playerSignPlaceholder')}
              class="w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-500/20 min-h-[44px]"
            />
          </div>
          <div>
            <label for="amount" class="block text-sm font-medium text-slate-700 mb-1.5">
              {t(locale, 'thailand.fields.amount')}
            </label>
            <input
              type="number"
              id="amount"
              name="amount"
              placeholder={t(locale, 'thailand.fields.amountPlaceholder')}
              min="0"
              step="0.01"
              required
              class="w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-500/20 min-h-[44px]"
            />
          </div>
          <div class="md:col-span-2">
            <label for="remark" class="block text-sm font-medium text-slate-700 mb-1.5">
              {t(locale, 'thailand.fields.remark')}
            </label>
            <input
              type="text"
              id="remark"
              name="remark"
              placeholder={t(locale, 'thailand.fields.remarkPlaceholder')}
              class="w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-500/20 min-h-[44px]"
            />
          </div>
          <div>
            <label for="playerMobile" class="block text-sm font-medium text-slate-700 mb-1.5">
              {t(locale, 'thailand.fields.playerMobile')}
            </label>
            <input
              type="text"
              id="playerMobile"
              name="playerMobile"
              placeholder={t(locale, 'thailand.fields.playerMobilePlaceholder')}
              class="w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-500/20 min-h-[44px]"
            />
          </div>
          <div>
            <label for="bankNameCreate" class="block text-sm font-medium text-slate-700 mb-1.5">
              {t(locale, 'thailand.fields.bankName')}
            </label>
            <input
              type="text"
              id="bankNameCreate"
              name="bankNameCreate"
              placeholder={t(locale, 'thailand.fields.bankNamePlaceholder')}
              class="w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-500/20 min-h-[44px]"
            />
          </div>
          <div>
            <label for="bankNumberCreate" class="block text-sm font-medium text-slate-700 mb-1.5">
              {t(locale, 'thailand.fields.bankNumber')}
            </label>
            <input
              type="text"
              id="bankNumberCreate"
              name="bankNumberCreate"
              placeholder={t(locale, 'thailand.fields.bankNumberPlaceholder')}
              class="w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-500/20 min-h-[44px]"
            />
          </div>
          <div>
            <label for="nameCreate" class="block text-sm font-medium text-slate-700 mb-1.5">
              {t(locale, 'thailand.fields.accountName')}
            </label>
            <input
              type="text"
              id="nameCreate"
              name="nameCreate"
              placeholder={t(locale, 'thailand.fields.accountNamePlaceholder')}
              class="w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-500/20 min-h-[44px]"
            />
          </div>
        </div>

        <div class="pt-2">
          <button
            type="submit"
            class="w-full rounded-lg bg-slate-800 px-4 py-3 text-sm font-medium text-white shadow-sm hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 min-h-[44px] transition-colors"
          >
            {t(locale, 'thailand.buttons.submit')}
          </button>
        </div>
      </form>
    </section>
  </main>
</div>
