---
import CoindPay from '../components/coindpay.astro';
import Thailand from '../components/thailand.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="tab-container">
		<div id="coindpay" class="tab-page">
			<a href="#coindpay" class="tab">CoindPay</a>
			<div class="panel">
				<CoindPay />
			</div>
		</div>
		<div id="thailand" class="tab-page">
			<a href="#thailand" class="tab">泰国代收</a>
			<div class="panel">
				<Thailand />
			</div>
		</div>
	</div>

	<script>
		if (!location.hash) {
			location.hash = 'coindpay';
		}
	</script>
</Layout>

<style>
	.tab-container {
		display: grid;
		grid-template-columns: auto auto;
		grid-template-rows: auto 1fr;
		gap: 0 1rem;
		min-height: 100vh;
	}

	.tab-page {
		display: contents;
	}

	.tab-page .tab {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 1rem;
		margin-bottom: 0.5rem;
		font-size: 0.9375rem;
		font-weight: 500;
		color: var(--tab-color, #475569);
		text-decoration: none;
		border-radius: 0.5rem;
		transition: color 0.15s, background 0.15s;
	}

	.tab-page .tab:hover {
		color: #0f172a;
		background: rgba(15, 23, 42, 0.06);
	}

	.tab-page:target .tab {
		color: #0f172a;
		background: rgba(15, 23, 42, 0.08);
		font-weight: 600;
	}

	#coindpay .tab {
		grid-column: 1;
		grid-row: 1;
	}

	#thailand .tab {
		grid-column: 2;
		grid-row: 1;
	}

	.tab-page .panel {
		grid-column: 1 / -1;
		grid-row: 2;
		display: none;
	}

	.tab-page:target .panel {
		display: block;
	}
</style>
